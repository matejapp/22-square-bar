# Copy to .env and fill in your values. Never commit the real .env.

# ─────────── Database ───────────
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306
DB_POOL_SIZE=10

# ─────────── Auth ───────────
# Must be ≥32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=12h

# ─────────── Server ───────────
PORT=3000

# Comma-separated allowed origins (include both http and https variants)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Path to the built React app (production only)
# STATIC_PATH=/home/<cpanel-user>/public_html
